AGENTICFLOW_ENV=development
AGENTICFLOW_DB_ENGINE=sqlite
AGENTICFLOW_SQLITE_PATH=agenticflow_demo.db
AGENTICFLOW_DATABASE_URL=postgresql://user:password@localhost:5432/agenticflow
